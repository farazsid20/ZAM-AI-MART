<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(ZamAiMart.Client.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found - ZAM AI MART</PageTitle>
        <LayoutView Layout="@typeof(ZamAiMart.Client.Layout.MainLayout)">
            <div class="max-w-2xl mx-auto px-4 py-24 text-center">
                <div class="text-8xl mb-6">🤖</div>
                <h1 class="text-4xl font-black text-gray-900 dark:text-white mb-4">404 - Page Not Found</h1>
                <p class="text-gray-600 dark:text-gray-400 mb-8">The page you're looking for doesn't exist.</p>
                <a href="/" class="bg-violet-600 text-white px-6 py-3 rounded-xl font-medium hover:bg-violet-700 transition-colors">
                    Go Home
                </a>
            </div>
        </LayoutView>
    </NotFound>
</Router>
