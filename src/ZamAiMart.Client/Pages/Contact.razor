@page "/contact"

<PageTitle>Contact - ZAM AI MART</PageTitle>

<div class="bg-gradient-to-r from-violet-700 to-indigo-700 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl sm:text-4xl font-black mb-2">Contact Us</h1>
        <p class="text-white/80">Get in touch with the ZAM AI MART team</p>
    </div>
</div>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Contact Info -->
        <div class="space-y-6">
            <h2 class="text-2xl font-black text-gray-900 dark:text-white">Get In Touch</h2>
            <p class="text-gray-600 dark:text-gray-400">
                Have a question about ZAM AI MART or want to submit a new AI tool? 
                We'd love to hear from you.
            </p>

            <!-- Phone -->
            <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-violet-100 dark:bg-violet-900/30 rounded-xl flex items-center justify-center shrink-0">
                        <svg class="w-6 h-6 text-violet-600" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-900 dark:text-white">Phone</h3>
                        <a href="tel:+919161007123" class="text-violet-600 dark:text-violet-400 hover:underline font-medium">
                            +91-9161007123
                        </a>
                    </div>
                </div>
            </div>

            <!-- Address -->
            <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-violet-100 dark:bg-violet-900/30 rounded-xl flex items-center justify-center shrink-0">
                        <svg class="w-6 h-6 text-violet-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-900 dark:text-white">Address</h3>
                        <address class="text-gray-600 dark:text-gray-400 not-italic leading-relaxed">
                            Sultanpur<br />
                            Uttar Pradesh<br />
                            Pin Code – 228001<br />
                            India
                        </address>
                    </div>
                </div>
            </div>

            <!-- Developer -->
            <div class="bg-gradient-to-br from-violet-50 to-indigo-50 dark:from-violet-900/20 dark:to-indigo-900/20 rounded-2xl border border-violet-200 dark:border-violet-700 p-5">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-gradient-to-br from-violet-600 to-indigo-600 rounded-xl flex items-center justify-center shrink-0">
                        <span class="text-white font-black">A</span>
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-900 dark:text-white">Developer</h3>
                        <p class="text-violet-600 dark:text-violet-400 font-medium">Ahmad Faraz Siddiqui</p>
                        <p class="text-gray-500 dark:text-gray-400 text-sm">Full-Stack Developer</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <div>
            <h2 class="text-2xl font-black text-gray-900 dark:text-white mb-6">Send a Message</h2>
            <form class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Your Name</label>
                    <input type="text" placeholder="Ahmad Faraz"
                           class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 transition-shadow" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email Address</label>
                    <input type="email" placeholder="your@email.com"
                           class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 transition-shadow" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Subject</label>
                    <input type="text" placeholder="Suggest a new AI tool..."
                           class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 transition-shadow" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Message</label>
                    <textarea rows="4" placeholder="Tell us about the AI tool you want to suggest..."
                              class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 transition-shadow resize-none"></textarea>
                </div>
                <button type="submit"
                        class="w-full bg-violet-600 hover:bg-violet-700 text-white font-bold py-3 rounded-xl transition-colors">
                    Send Message
                </button>
            </form>
        </div>
    </div>
</div>
