@page "/admin"
@using ZamAiMart.Client.Models
@using ZamAiMart.Client.Services
@using ZamAiMart.Client.Shared
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Admin Dashboard - ZAM AI MART</PageTitle>

<div class="bg-gradient-to-r from-gray-900 to-gray-800 text-white py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-violet-600 rounded-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M3 5a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2h-2.22l.123.489.804.804A1 1 0 0113 18H7a1 1 0 01-.707-1.707l.804-.804L7.22 15H5a2 2 0 01-2-2V5zm5.771 7H5V5h10v7H8.771z" clip-rule="evenodd" />
                </svg>
            </div>
            <div>
                <h1 class="text-2xl font-black">Admin Dashboard</h1>
                <p class="text-gray-400 text-sm">Manage AI tools and categories</p>
            </div>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5">
            <div class="text-3xl font-black text-violet-600">@_totalTools</div>
            <div class="text-gray-500 dark:text-gray-400 text-sm mt-1">Total AI Tools</div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5">
            <div class="text-3xl font-black text-emerald-600">@_freeTools</div>
            <div class="text-gray-500 dark:text-gray-400 text-sm mt-1">Free Tools</div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5">
            <div class="text-3xl font-black text-amber-600">@_featuredTools</div>
            <div class="text-gray-500 dark:text-gray-400 text-sm mt-1">Featured Tools</div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5">
            <div class="text-3xl font-black text-indigo-600">@_totalCategories</div>
            <div class="text-gray-500 dark:text-gray-400 text-sm mt-1">Categories</div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        <a href="/admin/tools" class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-lg hover:border-violet-200 dark:hover:border-violet-700 transition-all group">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-violet-100 dark:bg-violet-900/30 rounded-xl flex items-center justify-center group-hover:bg-violet-600 transition-colors">
                    <svg class="w-6 h-6 text-violet-600 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
                        <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">Manage AI Tools</h3>
                    <p class="text-gray-500 dark:text-gray-400 text-sm">Add, edit or delete tools</p>
                </div>
            </div>
        </a>
        <a href="/admin/categories" class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-lg hover:border-violet-200 dark:hover:border-violet-700 transition-all group">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-indigo-100 dark:bg-indigo-900/30 rounded-xl flex items-center justify-center group-hover:bg-indigo-600 transition-colors">
                    <svg class="w-6 h-6 text-indigo-600 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
                    </svg>
                </div>
                <div>
                    <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">Manage Categories</h3>
                    <p class="text-gray-500 dark:text-gray-400 text-sm">Add, edit or delete categories</p>
                </div>
            </div>
        </a>
        <a href="/tools" class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-lg hover:border-emerald-200 dark:hover:border-emerald-700 transition-all group">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900/30 rounded-xl flex items-center justify-center group-hover:bg-emerald-600 transition-colors">
                    <svg class="w-6 h-6 text-emerald-600 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div>
                    <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">View Live Site</h3>
                    <p class="text-gray-500 dark:text-gray-400 text-sm">See the public tools directory</p>
                </div>
            </div>
        </a>
    </div>

    <!-- Recent Tools -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6">
        <div class="flex items-center justify-between mb-5">
            <h2 class="text-lg font-bold text-gray-900 dark:text-white">Recent Tools</h2>
            <a href="/admin/tools" class="text-violet-600 dark:text-violet-400 text-sm hover:underline">View all →</a>
        </div>

        @if (_loading)
        {
            <LoadingSpinner Message="Loading..." />
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700">
                            <th class="text-left py-3 px-3 font-semibold text-gray-500 dark:text-gray-400">Tool</th>
                            <th class="text-left py-3 px-3 font-semibold text-gray-500 dark:text-gray-400 hidden sm:table-cell">Category</th>
                            <th class="text-left py-3 px-3 font-semibold text-gray-500 dark:text-gray-400">Price</th>
                            <th class="text-left py-3 px-3 font-semibold text-gray-500 dark:text-gray-400 hidden md:table-cell">Featured</th>
                            <th class="text-right py-3 px-3 font-semibold text-gray-500 dark:text-gray-400">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                        @foreach (var tool in _recentTools)
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                <td class="py-3 px-3">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-700 shrink-0">
                                            @if (!string.IsNullOrEmpty(tool.LogoUrl))
                                            {
                                                <img src="@tool.LogoUrl" alt="@tool.Name" class="w-full h-full object-cover" />
                                            }
                                            else
                                            {
                                                <span class="w-full h-full flex items-center justify-center text-xs">🤖</span>
                                            }
                                        </div>
                                        <div class="min-w-0">
                                            <div class="font-medium text-gray-900 dark:text-white truncate max-w-[150px]">@tool.Name</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3 px-3 text-gray-600 dark:text-gray-400 hidden sm:table-cell">
                                    @tool.CategoryIcon @tool.CategoryName
                                </td>
                                <td class="py-3 px-3">
                                    <span class="@(tool.IsFree ? "bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400" : "bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-400") text-xs font-bold px-2 py-0.5 rounded-md">
                                        @tool.FormattedPrice
                                    </span>
                                </td>
                                <td class="py-3 px-3 hidden md:table-cell">
                                    @if (tool.IsFeatured)
                                    {
                                        <span class="text-amber-500">⭐</span>
                                    }
                                    else
                                    {
                                        <span class="text-gray-300 dark:text-gray-600">—</span>
                                    }
                                </td>
                                <td class="py-3 px-3 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/admin/tools/edit/@tool.Id" class="text-xs text-violet-600 dark:text-violet-400 hover:underline">Edit</a>
                                        <button @onclick="() => DeleteTool(tool.Id)" class="text-xs text-red-500 hover:underline">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private int _totalTools;
    private int _freeTools;
    private int _featuredTools;
    private int _totalCategories;
    private List<AIToolDto> _recentTools = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var tools = await Api.GetLatestToolsAsync(50);
        _recentTools = tools.Take(10).ToList();
        _totalTools = tools.Count;
        _freeTools = tools.Count(t => t.IsFree);
        _featuredTools = tools.Count(t => t.IsFeatured);
        var cats = await Api.GetCategoriesAsync();
        _totalCategories = cats.Count;
        _loading = false;
    }

    private async Task DeleteTool(int id)
    {
        if (await Api.DeleteToolAsync(id))
        {
            _recentTools = _recentTools.Where(t => t.Id != id).ToList();
            _totalTools--;
            StateHasChanged();
        }
    }
}
