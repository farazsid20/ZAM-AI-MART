@page "/admin/tools"
@page "/admin/tools/edit/{Id:int}"
@using ZamAiMart.Client.Models
@using ZamAiMart.Client.Services
@using ZamAiMart.Client.Shared
@inject ApiService Api
@inject NavigationManager Nav

<PageTitle>Manage AI Tools - ZAM AI MART Admin</PageTitle>

<div class="bg-gradient-to-r from-gray-900 to-gray-800 text-white py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3">
            <a href="/admin" class="text-gray-400 hover:text-white transition-colors">← Dashboard</a>
            <span class="text-gray-600">/</span>
            <h1 class="text-xl font-black">@(Id.HasValue ? "Edit AI Tool" : "Manage AI Tools")</h1>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    @if (_showForm || Id.HasValue)
    {
        <!-- Add/Edit Form -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 mb-8">
            <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-6">
                @(Id.HasValue ? "Edit Tool" : "Add New AI Tool")
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tool Name *</label>
                    <input @bind="_form.Name" type="text" placeholder="e.g. ChatGPT"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Website URL *</label>
                    <input @bind="_form.WebsiteUrl" type="url" placeholder="https://example.com"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Logo URL</label>
                    <input @bind="_form.LogoUrl" type="url" placeholder="https://example.com/logo.png"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Category *</label>
                    <select @bind="_categoryIdStr"
                            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm">
                        <option value="">Select Category</option>
                        @foreach (var cat in _categories)
                        {
                            <option value="@cat.Id">@cat.Icon @cat.Name</option>
                        }
                    </select>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description *</label>
                    <textarea @bind="_form.Description" rows="3" placeholder="Short description of the tool..."
                              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm resize-none"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Pricing Type</label>
                    <select @bind="_form.PricingType" @bind:after="OnPricingTypeChanged"
                            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm">
                        <option value="@PricingType.Free">Free</option>
                        <option value="@PricingType.Freemium">Freemium</option>
                        <option value="@PricingType.Monthly">Monthly</option>
                        <option value="@PricingType.Yearly">Yearly</option>
                        <option value="@PricingType.OneTime">One-Time</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Price (₹) @(_form.IsFree ? "- Leave 0 for Free" : "")</label>
                    <input @bind="_form.Price" type="number" min="0" placeholder="0"
                           disabled="@_form.IsFree"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm disabled:opacity-50" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tags (comma-separated)</label>
                    <input @bind="_form.Tags" type="text" placeholder="ai,chatbot,free"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm" />
                </div>
                <div class="flex items-center gap-6">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input @bind="_form.IsFeatured" type="checkbox" class="rounded text-violet-600 w-4 h-4" />
                        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">⭐ Featured</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input @bind="_form.IsFree" type="checkbox" class="rounded text-emerald-600 w-4 h-4" />
                        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">✓ Is Free</span>
                    </label>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="mt-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 text-red-700 dark:text-red-400 px-4 py-3 rounded-xl text-sm">
                    @_errorMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <div class="mt-4 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-700 text-emerald-700 dark:text-emerald-400 px-4 py-3 rounded-xl text-sm">
                    @_successMessage
                </div>
            }

            <div class="flex gap-3 mt-6">
                <button @onclick="SubmitForm" disabled="@_saving"
                        class="bg-violet-600 hover:bg-violet-700 text-white px-6 py-2 rounded-xl font-medium transition-colors disabled:opacity-50 text-sm">
                    @(_saving ? "Saving..." : (Id.HasValue ? "Update Tool" : "Add Tool"))
                </button>
                <button @onclick="CancelForm" class="bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 px-6 py-2 rounded-xl font-medium hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors text-sm">
                    Cancel
                </button>
            </div>
        </div>
    }
    else
    {
        <!-- Add New Button -->
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-bold text-gray-900 dark:text-white">All AI Tools (@_tools.Count)</h2>
            <button @onclick="ShowAddForm"
                    class="bg-violet-600 hover:bg-violet-700 text-white px-4 py-2 rounded-xl font-medium transition-colors text-sm flex items-center gap-2">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
                Add New Tool
            </button>
        </div>
    }

    <!-- Tools Table -->
    @if (!Id.HasValue && !_showForm)
    {
        @if (_loading)
        {
            <LoadingSpinner Message="Loading tools..." />
        }
        else
        {
            <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                <div class="p-4 border-b border-gray-200 dark:border-gray-700">
                    <input type="text" @bind="_filterQuery" @bind:event="oninput"
                           placeholder="Filter tools by name..."
                           class="w-full max-w-xs px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm" />
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-gray-50 dark:bg-gray-700/50">
                            <tr>
                                <th class="text-left py-3 px-4 font-semibold text-gray-500 dark:text-gray-400">#</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-500 dark:text-gray-400">Tool</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-500 dark:text-gray-400 hidden sm:table-cell">Category</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-500 dark:text-gray-400">Price</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-500 dark:text-gray-400 hidden md:table-cell">Featured</th>
                                <th class="text-right py-3 px-4 font-semibold text-gray-500 dark:text-gray-400">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                            @foreach (var tool in FilteredTools)
                            {
                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                                    <td class="py-3 px-4 text-gray-400 text-xs">@tool.Id</td>
                                    <td class="py-3 px-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-lg bg-gray-100 dark:bg-gray-700 overflow-hidden shrink-0">
                                                @if (!string.IsNullOrEmpty(tool.LogoUrl))
                                                {
                                                    <img src="@tool.LogoUrl" alt="" class="w-full h-full object-cover" />
                                                }
                                                else
                                                {
                                                    <span class="w-full h-full flex items-center justify-center text-xs">🤖</span>
                                                }
                                            </div>
                                            <div>
                                                <div class="font-medium text-gray-900 dark:text-white">@tool.Name</div>
                                                <div class="text-gray-400 text-xs truncate max-w-[200px]">@tool.Description</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3 px-4 text-gray-600 dark:text-gray-400 text-xs hidden sm:table-cell">@tool.CategoryIcon @tool.CategoryName</td>
                                    <td class="py-3 px-4">
                                        <span class="@(tool.IsFree ? "bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400" : "bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-400") text-xs font-bold px-2 py-0.5 rounded">
                                            @tool.FormattedPrice
                                        </span>
                                    </td>
                                    <td class="py-3 px-4 hidden md:table-cell">
                                        @if (tool.IsFeatured) { <span class="text-amber-500 text-base">⭐</span> }
                                        else { <span class="text-gray-300 dark:text-gray-600 text-xs">—</span> }
                                    </td>
                                    <td class="py-3 px-4 text-right">
                                        <div class="flex items-center justify-end gap-2">
                                            <a href="/admin/tools/edit/@tool.Id" class="text-xs text-violet-600 dark:text-violet-400 hover:underline font-medium">Edit</a>
                                            <button @onclick="() => DeleteTool(tool.Id)" class="text-xs text-red-500 hover:underline font-medium">Delete</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private List<AIToolDto> _tools = new();
    private List<CategoryDto> _categories = new();
    private bool _loading = true;
    private bool _showForm;
    private bool _saving;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;
    private string _filterQuery = string.Empty;
    private string _categoryIdStr = string.Empty;

    private CreateAIToolDto _form = new();

    private IEnumerable<AIToolDto> FilteredTools =>
        string.IsNullOrWhiteSpace(_filterQuery)
            ? _tools
            : _tools.Where(t => t.Name.Contains(_filterQuery, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _categories = await Api.GetCategoriesAsync();
        if (Id.HasValue)
        {
            await LoadForEdit(Id.Value);
        }
        else
        {
            var result = await Api.GetToolsAsync(new AIToolSearchDto { PageSize = 500 });
            _tools = result.Items;
        }
        _loading = false;
    }

    private async Task LoadForEdit(int id)
    {
        var tool = await Api.GetToolAsync(id);
        if (tool != null)
        {
            _form = new CreateAIToolDto
            {
                Name = tool.Name,
                Description = tool.Description,
                LogoUrl = tool.LogoUrl,
                WebsiteUrl = tool.WebsiteUrl,
                CategoryId = tool.CategoryId,
                Price = tool.Price,
                PricingType = tool.PricingType,
                IsFree = tool.IsFree,
                IsFeatured = tool.IsFeatured,
                Tags = tool.Tags
            };
            _categoryIdStr = tool.CategoryId.ToString();
        }
    }

    private void ShowAddForm()
    {
        _form = new CreateAIToolDto();
        _categoryIdStr = string.Empty;
        _showForm = true;
        _errorMessage = string.Empty;
        _successMessage = string.Empty;
    }

    private void CancelForm()
    {
        _showForm = false;
        if (Id.HasValue) Nav.NavigateTo("/admin/tools");
    }

    private async Task SubmitForm()
    {
        _errorMessage = string.Empty;
        _successMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(_form.Name) || string.IsNullOrWhiteSpace(_form.WebsiteUrl))
        {
            _errorMessage = "Name and Website URL are required.";
            return;
        }

        if (!string.IsNullOrEmpty(_categoryIdStr))
            _form.CategoryId = int.Parse(_categoryIdStr);

        if (_form.CategoryId == 0)
        {
            _errorMessage = "Please select a category.";
            return;
        }

        _saving = true;
        try
        {
            if (Id.HasValue)
            {
                var updateDto = new UpdateAIToolDto
                {
                    Name = _form.Name,
                    Description = _form.Description,
                    LogoUrl = _form.LogoUrl,
                    WebsiteUrl = _form.WebsiteUrl,
                    CategoryId = _form.CategoryId,
                    Price = _form.Price,
                    PricingType = _form.PricingType,
                    IsFree = _form.IsFree,
                    IsFeatured = _form.IsFeatured,
                    Tags = _form.Tags
                };
                var result = await Api.UpdateToolAsync(Id.Value, updateDto);
                if (result != null)
                {
                    _successMessage = "Tool updated successfully!";
                    await Task.Delay(1000);
                    Nav.NavigateTo("/admin/tools");
                }
                else
                {
                    _errorMessage = "Failed to update tool.";
                }
            }
            else
            {
                var result = await Api.CreateToolAsync(_form);
                if (result != null)
                {
                    _successMessage = "Tool added successfully!";
                    _tools.Insert(0, result);
                    _form = new CreateAIToolDto();
                    _categoryIdStr = string.Empty;
                    _showForm = false;
                }
                else
                {
                    _errorMessage = "Failed to add tool.";
                }
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteTool(int id)
    {
        if (await Api.DeleteToolAsync(id))
            _tools = _tools.Where(t => t.Id != id).ToList();
    }

    private void OnPricingTypeChanged()
    {
        _form.IsFree = _form.PricingType == PricingType.Free;
        if (_form.IsFree) _form.Price = 0;
    }
}
