@page "/admin/categories"
@using ZamAiMart.Client.Models
@using ZamAiMart.Client.Services
@using ZamAiMart.Client.Shared
@inject ApiService Api

<PageTitle>Manage Categories - ZAM AI MART Admin</PageTitle>

<div class="bg-gradient-to-r from-gray-900 to-gray-800 text-white py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3">
            <a href="/admin" class="text-gray-400 hover:text-white transition-colors">← Dashboard</a>
            <span class="text-gray-600">/</span>
            <h1 class="text-xl font-black">Manage Categories</h1>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Form -->
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6">
                <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-5">
                    @(_editingId.HasValue ? "Edit Category" : "Add Category")
                </h2>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Name *</label>
                        <input @bind="_form.Name" type="text" placeholder="AI Chatbots"
                               class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Slug *</label>
                        <input @bind="_form.Slug" type="text" placeholder="ai-chatbots"
                               class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Icon (Emoji) *</label>
                        <input @bind="_form.Icon" type="text" placeholder="💬"
                               class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
                        <textarea @bind="_form.Description" rows="3" placeholder="Category description..."
                                  class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-violet-500 text-sm resize-none"></textarea>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_message))
                {
                    <div class="mt-4 @(_isError ? "bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 border-red-200 dark:border-red-700" : "bg-emerald-50 dark:bg-emerald-900/20 text-emerald-700 dark:text-emerald-400 border-emerald-200 dark:border-emerald-700") border px-4 py-3 rounded-xl text-sm">
                        @_message
                    </div>
                }

                <div class="flex gap-2 mt-5">
                    <button @onclick="Submit" disabled="@_saving"
                            class="flex-1 bg-violet-600 hover:bg-violet-700 text-white py-2 rounded-xl font-medium transition-colors disabled:opacity-50 text-sm">
                        @(_saving ? "..." : (_editingId.HasValue ? "Update" : "Add Category"))
                    </button>
                    @if (_editingId.HasValue)
                    {
                        <button @onclick="CancelEdit" class="px-4 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-600 text-sm transition-colors">
                            Cancel
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- List -->
        <div class="lg:col-span-2">
            @if (_loading)
            {
                <LoadingSpinner />
            }
            else
            {
                <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                    <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
                        <h2 class="font-bold text-gray-900 dark:text-white">All Categories (@_categories.Count)</h2>
                    </div>
                    <div class="divide-y divide-gray-100 dark:divide-gray-700">
                        @foreach (var cat in _categories)
                        {
                            <div class="flex items-center justify-between p-4 hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                                <div class="flex items-center gap-3">
                                    <span class="text-2xl">@cat.Icon</span>
                                    <div>
                                        <div class="font-medium text-gray-900 dark:text-white">@cat.Name</div>
                                        <div class="text-xs text-gray-500 dark:text-gray-400">@cat.Slug • @cat.ToolCount tools</div>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3">
                                    <button @onclick="() => EditCategory(cat)" class="text-xs text-violet-600 dark:text-violet-400 hover:underline font-medium">Edit</button>
                                    <button @onclick="() => DeleteCategory(cat.Id)" class="text-xs text-red-500 hover:underline font-medium">Delete</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<CategoryDto> _categories = new();
    private bool _loading = true;
    private bool _saving;
    private int? _editingId;
    private string _message = string.Empty;
    private bool _isError;
    private CreateCategoryDto _form = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
        _loading = false;
    }

    private async Task LoadCategories()
    {
        _categories = await Api.GetCategoriesAsync();
    }

    private void EditCategory(CategoryDto cat)
    {
        _editingId = cat.Id;
        _form = new CreateCategoryDto
        {
            Name = cat.Name,
            Slug = cat.Slug,
            Icon = cat.Icon,
            Description = cat.Description
        };
        _message = string.Empty;
    }

    private void CancelEdit()
    {
        _editingId = null;
        _form = new CreateCategoryDto();
        _message = string.Empty;
    }

    private async Task Submit()
    {
        _message = string.Empty;
        if (string.IsNullOrWhiteSpace(_form.Name) || string.IsNullOrWhiteSpace(_form.Slug))
        {
            _message = "Name and Slug are required.";
            _isError = true;
            return;
        }

        _saving = true;
        try
        {
            if (_editingId.HasValue)
            {
                var result = await Api.UpdateCategoryAsync(_editingId.Value, new UpdateCategoryDto
                {
                    Name = _form.Name,
                    Slug = _form.Slug,
                    Icon = _form.Icon,
                    Description = _form.Description
                });
                if (result != null)
                {
                    _message = "Category updated!";
                    _isError = false;
                    await LoadCategories();
                    CancelEdit();
                }
                else
                {
                    _message = "Update failed.";
                    _isError = true;
                }
            }
            else
            {
                var result = await Api.CreateCategoryAsync(_form);
                if (result != null)
                {
                    _message = "Category added!";
                    _isError = false;
                    _categories.Add(result);
                    _form = new CreateCategoryDto();
                }
                else
                {
                    _message = "Failed to add category.";
                    _isError = true;
                }
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteCategory(int id)
    {
        if (await Api.DeleteCategoryAsync(id))
            _categories = _categories.Where(c => c.Id != id).ToList();
    }
}
