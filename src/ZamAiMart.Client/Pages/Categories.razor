@page "/categories"
@using ZamAiMart.Client.Models
@using ZamAiMart.Client.Services
@using ZamAiMart.Client.Shared
@inject ApiService Api

<PageTitle>Categories - ZAM AI MART</PageTitle>

<div class="bg-gradient-to-r from-violet-700 to-indigo-700 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl sm:text-4xl font-black mb-2">AI Tool Categories</h1>
        <p class="text-white/80">Find the right AI tool for your specific need</p>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    @if (_loading)
    {
        <LoadingSpinner Message="Loading categories..." />
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var cat in _categories)
            {
                <a href="/tools?categoryId=@cat.Id"
                   class="group bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-xl hover:shadow-violet-100 dark:hover:shadow-violet-900/20 hover:border-violet-200 dark:hover:border-violet-700 transition-all duration-300">
                    <div class="flex items-start gap-4">
                        <div class="text-4xl group-hover:scale-110 transition-transform duration-300">@cat.Icon</div>
                        <div class="flex-1 min-w-0">
                            <h3 class="font-bold text-lg text-gray-900 dark:text-white group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">@cat.Name</h3>
                            <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">@cat.Description</p>
                            <div class="mt-3 flex items-center justify-between">
                                <span class="text-xs bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-400 px-3 py-1 rounded-full font-medium">
                                    @cat.ToolCount tools
                                </span>
                                <span class="text-violet-600 dark:text-violet-400 text-sm font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
                                    Browse →
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
</div>

@code {
    private List<CategoryDto> _categories = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _categories = await Api.GetCategoriesAsync();
        _loading = false;
    }
}
