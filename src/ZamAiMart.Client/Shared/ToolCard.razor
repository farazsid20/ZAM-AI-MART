@using ZamAiMart.Client.Models

<div class="group bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5 hover:shadow-xl hover:shadow-violet-100 dark:hover:shadow-violet-900/20 hover:border-violet-200 dark:hover:border-violet-700 transition-all duration-300 cursor-pointer flex flex-col"
     @onclick="OpenWebsite">
    <!-- Header -->
    <div class="flex items-start justify-between mb-3">
        <div class="flex items-center space-x-3">
            <div class="w-12 h-12 rounded-xl overflow-hidden bg-gray-100 dark:bg-gray-700 flex items-center justify-center shrink-0">
                @if (!string.IsNullOrEmpty(Tool.LogoUrl))
                {
                    <img src="@Tool.LogoUrl" alt="@Tool.Name logo" class="w-full h-full object-cover"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                    <span class="text-xl hidden">@GetEmoji()</span>
                }
                else
                {
                    <span class="text-xl">🤖</span>
                }
            </div>
            <div class="min-w-0">
                <h3 class="font-bold text-gray-900 dark:text-white text-sm truncate group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">@Tool.Name</h3>
                <span class="text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1">
                    <span>@Tool.CategoryIcon</span>
                    <span class="truncate">@Tool.CategoryName</span>
                </span>
            </div>
        </div>
        @if (Tool.IsFeatured)
        {
            <span class="shrink-0 text-xs bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 px-2 py-0.5 rounded-full font-medium">⭐ Featured</span>
        }
    </div>

    <!-- Description -->
    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed line-clamp-2 flex-1 mb-4">@Tool.Description</p>

    <!-- Footer -->
    <div class="flex items-center justify-between mt-auto pt-3 border-t border-gray-100 dark:border-gray-700">
        <span class="@(Tool.IsFree ? "bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400" : "bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-400") text-xs font-bold px-2.5 py-1 rounded-lg">
            @Tool.FormattedPrice
        </span>
        <button @onclick:stopPropagation="true" @onclick="OpenWebsite"
                class="text-xs bg-violet-600 hover:bg-violet-700 text-white px-3 py-1.5 rounded-lg font-medium transition-colors flex items-center gap-1">
            Visit
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public AIToolDto Tool { get; set; } = null!;
    [Inject] private IJSRuntime JS { get; set; } = null!;

    private async Task OpenWebsite()
    {
        await JS.InvokeVoidAsync("open", Tool.WebsiteUrl, "_blank");
    }

    private string GetEmoji() => Tool.CategoryIcon switch
    {
        "💬" => "💬",
        "🎨" => "🎨",
        "🎬" => "🎬",
        "💻" => "💻",
        "✍️" => "✍️",
        "🎙️" => "🎙️",
        "🎵" => "🎵",
        "📈" => "📈",
        "⚡" => "⚡",
        "🖌️" => "🖌️",
        _ => "🤖"
    };
}
