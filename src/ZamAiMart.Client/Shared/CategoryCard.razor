@using ZamAiMart.Client.Models
@inject NavigationManager Nav

<div @onclick="GoToCategory"
     class="group bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-xl hover:shadow-violet-100 dark:hover:shadow-violet-900/20 hover:border-violet-200 dark:hover:border-violet-700 transition-all duration-300 cursor-pointer text-center">
    <div class="text-4xl mb-3 group-hover:scale-110 transition-transform duration-300">@Category.Icon</div>
    <h3 class="font-bold text-gray-900 dark:text-white mb-1 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">@Category.Name</h3>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-2 line-clamp-2">@Category.Description</p>
    <span class="inline-block text-xs bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-400 px-2.5 py-1 rounded-full font-medium">
        @Category.ToolCount tools
    </span>
</div>

@code {
    [Parameter, EditorRequired] public CategoryDto Category { get; set; } = null!;

    private void GoToCategory()
    {
        Nav.NavigateTo($"/tools?categoryId={Category.Id}");
    }
}
